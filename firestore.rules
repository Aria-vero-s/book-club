rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Books ──────────────────────────────────────────────────────────────────
    // Anyone can read. Client writes are disabled by default.
    match /books/{bookId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Reviews ────────────────────────────────────────────────────────────────
    // Anyone can read. Authenticated users can create their own.
    // Only the author can update or delete.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Reading Status ─────────────────────────────────────────────────────────
    // Anyone can read (used for community stats).
    // Only the owner can write their own status document.
    match /readingStatus/{statusId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Votes ──────────────────────────────────────────────────────────────────
    // Anyone can read (used for live vote counts).
    // Only the owner can write their own vote document.
    match /votes/{voteId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Authenticated users can read profiles.
    // Users can only write their own profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // ── Suggestions ─────────────────────────────────────────────────────────────
    // Anyone can read. Authenticated users can manage only their own suggestion.
    match /suggestions/{suggestionId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Supports ────────────────────────────────────────────────────────────────
    // Anyone can read. Authenticated users can create supports on their own behalf.
    // Deleting support is limited to the support owner.
    match /supports/{supportId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── Replies ─────────────────────────────────────────────────────────────────
    // Anyone can read. Authenticated users can create replies as themselves.
    match /replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Notifications ───────────────────────────────────────────────────────────
    // Only recipients can read/update/delete their notifications.
    // Anyone authenticated can create a notification where senderId is themselves.
    match /notifications/{notificationId} {
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                                  && resource.data.recipientId == request.auth.uid;
    }
  }
}
